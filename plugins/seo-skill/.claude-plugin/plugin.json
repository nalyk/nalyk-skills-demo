{
  "name": "seo-skill",
  "description": "Deterministic SEO analysis engine. 98 atomic checks, async multi-page crawler, real CWV via PageSpeed Insights, optional GSC integration for real search data, internal link graph with PageRank, auto-fix generation, audit history with regression detection, and CI/CD integration.",
  "version": "2.2.0",
  "author": { "name": "nalyk" },
